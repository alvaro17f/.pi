{
  "lastChangelogVersion": "0.75.0",
  "defaultProvider": "ollama-cloud",
  "defaultModel": "glm-5.1",
  "theme": "catppuccin-mocha",
  "npmCommand": [
    "npm"
  ],
  "enableInstallTelemetry": false,
  "quietStartup": false,
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "medium",
  "terminal": {
    "showTerminalProgress": true
  },
  "packages": [
    "npm:@getpaseo/cli",
    "npm:@ifi/pi-plan",
    "npm:@lpirito/pi-diffloop",
    "npm:@sting8k/pi-vcc",
    "npm:context-mode",
    "npm:pi-ask-mode",
    "npm:pi-mcp-adapter",
    "npm:pi-rtk-optimizer",
    "npm:pi-secret-guard",
    "npm:pi-subagents",
    "npm:pi-tool-display"
  ],
  "extensionSettings": {
    "caveman": "full",
    "notifications": true
  }
}
