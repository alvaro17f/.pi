{
  "lastChangelogVersion": "0.67.1",
  "defaultProvider": "ollama-cloud",
  "defaultModel": "glm-5.1:cloud",
  "theme": "catppuccin-mocha",
  "enableInstallTelemetry": false,
  "quietStartup": true,
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:@0xkobold/pi-ollama",
    "npm:@ifi/pi-plan",
    {
      "source": "npm:@lpirito/pi-diffloop",
      "extensions": [
        "-dist/index.js"
      ]
    },
    "npm:@tintinweb/pi-subagents",
    "npm:pi-ollama-web-search",
    {
      "source": "npm:tau-mirror",
      "extensions": [
        "-extensions/mirror-server.ts"
      ]
    },
    "npm:pi-secret-guard"
  ],
  "extensionSettings": {
    "safeGuard": false,
    "caveman": "ultra"
  }
}
